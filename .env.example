# MAX · Sistema de IA Distribuido — variables de entorno
# Copiar a .env y completar. En producción usar secrets (Fly.io / EC2), no este archivo.

# Modelos
ANTHROPIC_API_KEY=
OLLAMA_API_KEY=
OLLAMA_CLOUD_URL=https://api.ollama.com

# Memoria (Supabase)
SUPABASE_URL=
SUPABASE_KEY=

# Auth entre servicios (JWT HS256)
DISPATCH_SECRET=

# Canal Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# URLs internas de servicios
DISPATCH_URL=http://dispatch:8001
